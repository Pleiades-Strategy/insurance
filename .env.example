# BillTrack50 API key (https://www.billtrack50.com)
billtrack50_key=your_key_here

# LegiScan API key (https://legiscan.com/legiscan)
legiscan_key=your_key_here

# OpenAI API key (optional, for future LLM features)
open_ai_key=your_key_here

# Airtable — personal access token (https://airtable.com/create/tokens)
# Needs: data.records:read scope on your base
airtable_key=your_pat_here

# Airtable base ID — found in the URL: airtable.com/appXXXXXXXXXXXXXX/...
airtable_base_id=appXXXXXXXXXXXXXX
